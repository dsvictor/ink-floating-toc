body.enable-pill-container.enable-horizontal-solid-line-style .workspace-leaf-content .floating-toc-div .heading-list-item[data-level='5']::before { width: calc((6px * var(--toc-bar-multiplier,1)) + (var(--toc-pill-padding) * 2)) !important; }
